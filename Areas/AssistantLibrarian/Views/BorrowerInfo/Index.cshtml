@{
    ViewData["Title"] = "Borrower Info";
}
<h2><i class="bi bi-person me-2"></i>Borrower Information</h2>
<p class="text-muted">Scan borrower barcode or search by name to view limited information.</p>
<hr />

<div class="card">
    <div class="card-body">
        <div class="mb-2">
            <label class="form-label fw-bold">Scan or type barcode</label>
            <input type="text" id="barcodeInput" class="form-control form-control-lg" placeholder="Scan barcode..." autofocus autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" />
        </div>
        <div class="mb-2">
            <label class="form-label fw-bold">Or search by name</label>
            <input type="text" id="searchBorrower" class="form-control" placeholder="Type name..." />
        </div>
        <div id="borrowerResult" class="mb-2"></div>
        <div id="result" class="mt-3"></div>
    </div>
</div>

@section Scripts {
    <script>
        let timeout;

        function lookupBorrower(barcode) {
            $.post('@Url.Action("Lookup")', { barcode: barcode }, function(res) {
                if (res.success) {
                    const b = res.borrower;
                    $('#result').html(`<div class="alert alert-info">
                        <strong>${b.firstName} ${b.lastName}</strong><br/>
                        Barcode: <code>${b.barcode}</code><br/>
                        ${b.grade ? 'Grade: ' + b.grade + '<br/>' : ''}
                        ${b.idNumber ? 'ID: ' + b.idNumber + '<br/>' : ''}
                        ${b.email ? 'Email: ' + b.email + '<br/>' : ''}
                        ${b.phone ? 'Phone: ' + b.phone : ''}
                    </div>`);
                } else {
                    $('#result').html(`<div class="alert alert-danger">${res.message}</div>`);
                }
            });
        }

        function searchBorrowerByName(term) {
            $.getJSON('@Url.Action("SearchBorrower")', { term: term }, function(data) {
                if (data.length === 0) {
                    $('#borrowerResult').html('<div class="text-muted">No matches.</div>');
                } else {
                    let html = '<ul class="list-group">';
                    data.forEach(b => {
                        html += `<li class="list-group-item list-group-item-action" onclick="selectBorrower('${b.barcode}')">
                            <strong>${b.name}</strong> <code>${b.barcode}</code> ${b.grade ? '-' + b.grade : ''}</li>`;
                    });
                    html += '</ul>';
                    $('#borrowerResult').html(html);
                }
            });
        }

        function selectBorrower(barcode) {
            $('#borrowerResult').html('');
            $('#searchBorrower').val('');
            $('#barcodeInput').val(barcode);
            lookupBorrower(barcode);
        }

        $('#barcodeInput').on('input', function() {
            clearTimeout(timeout);
            const val = this.value.trim();
            if (val.length > 3) {
                timeout = setTimeout(() => lookupBorrower(val), 400);
            }
        });

        $('#searchBorrower').on('input', function() {
            clearTimeout(timeout);
            const val = this.value.trim();
            if (val.length > 2) {
                timeout = setTimeout(() => searchBorrowerByName(val), 400);
            } else {
                $('#borrowerResult').html('');
            }
        });
    </script>
}
