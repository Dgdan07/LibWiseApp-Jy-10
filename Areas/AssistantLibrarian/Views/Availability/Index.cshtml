@model List<Book>
@{
    ViewData["Title"] = "Availability";
}
<h2><i class="bi bi-search me-2"></i>Book Availability</h2>
<hr />

<form method="get" class="row g-2 mb-3 align-items-end">
    <div class="col-auto">
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Search title, author, ISBN..." value="@ViewBag.Search" style="width: 260px;" />
    </div>
    <div class="col-auto">
        <button class="btn btn-sm btn-primary" type="submit"><i class="bi bi-search"></i></button>
        @if (!string.IsNullOrEmpty(ViewBag.Search))
        {
            <a asp-action="Index" class="btn btn-sm btn-outline-danger">Clear</a>
        }
    </div>
</form>

<div id="availabilityContainer" data-ajax-page>
<div class="row">
    @if (Model.Count == 0)
    {
        <div class="col-12"><p class="text-muted text-center py-4">No books found.</p></div>
    }
    @foreach (var book in Model)
    {
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <div class="cover-wrap cover-wrap-card">
                    <i class="bi bi-book cover-placeholder-icon"></i>
                    <img src="/Books/Cover/@book.Id" alt="@book.Title" class="cover-img d-none"
                         onload="this.classList.remove('d-none'); this.previousElementSibling.classList.add('d-none');"
                         onerror="this.classList.add('d-none');" />
                </div>
                <div class="card-body py-2 px-3">
                    <h6 class="card-title mb-1">@book.Title</h6>
                    <small class="text-muted">@book.Author</small>
                    <hr class="my-1" />
                    <div class="d-flex justify-content-between mb-1 small">
                        <span>Total:</span>
                        <strong>@book.TotalCopies</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-1 small">
                        <span>Available:</span>
                        <strong>@book.AvailableCopies</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-1 small">
                        <span>Status:</span>
                        @if (book.AvailableCopies > 0)
                        {
                            <span style="color: green;">Available</span>
                        }
                        else if (book.AvailableCopies == 0 && book.TotalCopies > 0)
                        {
                            <span style="color: darkorange;">All Borrowed</span>
                        }
                        else
                        {
                            <span style="color: red;">Unavailable</span>
                        }
                    </div>
                    @if (book.ShelfLocation != null)
                    {
                        <div class="d-flex justify-content-between small">
                            <span>Shelf:</span>
                            <code>@book.ShelfLocation</code>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
<partial name="_PaginationNumbered" />
</div>
