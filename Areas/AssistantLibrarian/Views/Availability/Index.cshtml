@model List<Book>
@{
    ViewData["Title"] = "Availability";
}
<h2><i class="bi bi-search me-2"></i>Book Availability</h2>
<hr />
<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" class="form-control form-control-lg" placeholder="Search title, author, ISBN..." value="@ViewBag.Search" />
        <button class="btn btn-primary btn-lg" type="submit"><i class="bi bi-search"></i></button>
        @if (!string.IsNullOrEmpty(ViewBag.Search))
        {
            <a asp-action="Index" class="btn btn-outline-danger btn-lg">Clear</a>
        }
    </div>
</form>

<div id="availabilityContainer" data-ajax-page>
<partial name="_PaginationNumbered" />
<div class="row">
    @if (Model.Count == 0)
    {
        <div class="col-12"><p class="text-muted text-center py-5">No books found.</p></div>
    }
    @foreach (var book in Model)
    {
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">@book.Title</h5>
                    <p class="card-subtitle text-muted">@book.Author</p>
                    <hr />
                    <p class="mb-1">Available: <strong class="@(book.AvailableCopies > 0 ? "text-success" : "text-danger")">@book.AvailableCopies</strong> / @book.TotalCopies</p>
                    <p class="mb-1">Shelf: <code>@(book.ShelfLocation ?? "-")</code></p>
                    @if (book.AvailableCopies > 0)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">All Borrowed</span>
                    }
                </div>
            </div>
        </div>
    }
</div>
</div>
