@{
    ViewData["Title"] = "Fine Collection";
}
<h2><i class="bi bi-cash-coin me-2"></i>Fine Collection</h2>
<p class="text-muted">Scan borrower barcode to view and collect unpaid fines.</p>
<hr />

<div class="card mb-3">
    <div class="card-body">
        <label class="form-label fw-bold">Borrower Barcode</label>
        <input type="text" id="barcodeInput" class="form-control form-control-lg" placeholder="Scan barcode..." autofocus />
        <div id="borrowerInfo" class="mt-2 text-muted small">Awaiting scan...</div>
    </div>
</div>

<div id="finesList"></div>
<div id="resultAlert" class="mt-2" style="display:none;"></div>

@section Scripts {
    <script>
        let timeout;
        $('#barcodeInput').on('input', function() {
            clearTimeout(timeout);
            const val = this.value.trim();
            if (val.length > 3) {
                timeout = setTimeout(() => {
                    $.post('@Url.Action("Search")', { borrowerBarcode: val }, function(res) {
                        if (res.success) {
                            $('#borrowerInfo').html(`<span class="text-success"><i class="bi bi-person-check"></i> <strong>${res.borrowerName}</strong></span>`);
                            if (res.fines.length === 0) {
                                $('#finesList').html('<div class="alert alert-success">No unpaid fines.</div>');
                                return;
                            }
                            let html = '<div class="list-group">';
                            let total = 0;
                            res.fines.forEach(f => {
                                total += f.amount;
                                html += `<div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div><strong>${f.bookTitle}</strong><br/><small>Fine: PHP ${f.amount.toFixed(2)}</small></div>
                                    <button class="btn btn-primary" onclick="payFine(${f.id})">Collect PHP ${f.amount.toFixed(2)}</button>
                                </div>`;
                            });
                            html += `<div class="list-group-item fw-bold">Total: PHP ${total.toFixed(2)}</div>`;
                            html += '</div>';
                            $('#finesList').html(html);
                        } else {
                            $('#borrowerInfo').html(`<span class="text-danger">${res.message}</span>`);
                            $('#finesList').html('');
                        }
                    });
                }, 400);
            }
        });

        function payFine(id) {
            if (!confirm('Collect payment for this fine?')) return;
            $.post('@Url.Action("Pay")', { fineId: id }, function(res) {
                if (res.success) {
                    $('#resultAlert').html(`<div class="alert alert-success">${res.message}</div>`).show();
                    $('#barcodeInput').val('').focus();
                    $('#finesList').html('');
                    $('#borrowerInfo').html('<span class="text-muted small">Awaiting scan...</span>');
                    setTimeout(() => $('#resultAlert').hide(), 5000);
                } else { alert(res.message); }
            });
        }
    </script>
}
