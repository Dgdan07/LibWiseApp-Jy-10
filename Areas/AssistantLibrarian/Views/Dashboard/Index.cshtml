@{
    ViewData["Title"] = "AL Dashboard";
}
<h2><i class="bi bi-speedometer2 me-2"></i>Assistant Librarian Dashboard</h2>
<p class="text-muted">Your activity today.</p>
<hr />
<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card text-bg-primary">
            <div class="card-body">
                <h5 class="card-title">Today's Borrowings</h5>
                <p class="card-text display-6">@ViewBag.TodayBorrowings</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card text-bg-success">
            <div class="card-body">
                <h5 class="card-title">Today's Returns</h5>
                <p class="card-text display-6">@ViewBag.TodayReturns</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card text-bg-warning">
            <div class="card-body">
                <h5 class="card-title">Fines Collected</h5>
                <p class="card-text display-6">PHP @ViewBag.TodayFinesCollected.ToString("F2")</p>
            </div>
        </div>
    </div>
</div>
