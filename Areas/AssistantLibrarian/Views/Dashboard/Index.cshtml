@{
    ViewData["Title"] = "AL Dashboard";
}
<h2><i class="bi bi-speedometer2 me-2"></i>Assistant Librarian Dashboard</h2>
<p class="text-muted">Your activity today.</p>
<hr />
<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm dashboard-card" style="border-left: 4px solid #4361ee;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">
                        <p class="text-muted small mb-1">Today's Borrowings</p>
                        <p class="fs-3 fw-semibold mb-0 text-end">@ViewBag.TodayBorrowings</p>
                    </div>
                    <i class="bi bi-arrow-right-circle fs-3 ms-3" style="color: #4361ee;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm dashboard-card" style="border-left: 4px solid #10b981;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">
                        <p class="text-muted small mb-1">Today's Returns</p>
                        <p class="fs-3 fw-semibold mb-0 text-end">@ViewBag.TodayReturns</p>
                    </div>
                    <i class="bi bi-arrow-left-circle fs-3 ms-3" style="color: #10b981;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm dashboard-card" style="border-left: 4px solid #0891b2;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">
                        <p class="text-muted small mb-1">Fines Collected</p>
                        <p class="fs-3 fw-semibold mb-0 text-end">₱ @ViewBag.TodayFinesCollected.ToString("N2")</p>
                    </div>
                    <i class="bi bi-cash-coin fs-3 ms-3" style="color: #0891b2;"></i>
                </div>
            </div>
        </div>
    </div>
</div>
