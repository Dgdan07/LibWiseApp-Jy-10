@{
    ViewData["Title"] = "Borrowing";
}
<h2><i class="bi bi-arrow-right-circle me-2"></i>Borrowing</h2>
<p class="text-muted">Scan borrower barcode then select book to process borrowing.</p>
<hr />

<div class="row">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-header fw-bold">Step 1: Borrower</div>
            <div class="card-body">
                <label class="form-label">Scan borrower barcode</label>
                <input type="text" id="barcodeInput" class="form-control form-control-lg" placeholder="Scan barcode..." autofocus autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" />
                <div id="borrowerResult" class="mt-2"></div>
                <input type="hidden" id="borrowerId" />
                <input type="hidden" id="borrowerBarcode" />
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-header fw-bold">Step 2: Book</div>
            <div class="card-body">
                <label class="form-label">Search book</label>
                <input type="text" id="searchBook" class="form-control" placeholder="Type title..." disabled />
                <div id="bookResult" class="mt-2"></div>
                <input type="hidden" id="bookId" />
            </div>
        </div>
    </div>
</div>

<button id="borrowBtn" class="btn btn-primary btn-lg w-100" disabled>
    <i class="bi bi-check-circle me-1"></i>Confirm Borrowing
</button>

@section Scripts {
    <script src="~/js/assistant-operations.js"></script>
}
