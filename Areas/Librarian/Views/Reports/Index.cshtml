@{
    ViewData["Title"] = "Reports";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-file-earmark-bar-graph me-2"></i>Operational Reports</h2>
    <a asp-action="ExportCsv" class="btn btn-success"><i class="bi bi-download me-1"></i>Export CSV</a>
</div>
<hr />

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm dashboard-card" style="border-left: 4px solid #f59e0b; cursor: pointer;" onclick="showActiveBorrowings()">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-arrow-right-circle fs-2" style="color: #f59e0b;"></i>
                        <span class="text-muted small">Active Borrowings</span>
                    </div>
                    <p class="fs-3 fw-semibold mb-0 text-end">@ViewBag.ActiveBorrowings</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm dashboard-card" style="border-left: 4px solid #ef4444; cursor: pointer;" onclick="showOverdueBorrowings()">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-triangle fs-2" style="color: #ef4444;"></i>
                        <span class="text-muted small">Overdue</span>
                    </div>
                    <p class="fs-3 fw-semibold mb-0 text-end">@ViewBag.OverdueCount</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm dashboard-card" style="border-left: 4px solid #0891b2;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-cash-coin fs-2" style="color: #0891b2;"></i>
                        <span class="text-muted small">Unpaid Fines</span>
                    </div>
                    <p class="fs-3 fw-semibold mb-0 text-end">@ViewBag.UnpaidFinesCount</p>
                </div>
            </div>
        </div>
    </div>
</div>

<h4 class="mt-4">Overdue Books</h4>
<div class="card mb-4">
    <div class="card-body p-0 table-responsive">
        <table class="table table-striped mb-0">
            <thead class="table-dark">
                <tr><th>Book</th><th>Borrower</th><th>Due Date</th><th>Days Overdue</th></tr>
            </thead>
            <tbody>
                @foreach (var r in ViewBag.OverdueBooks as List<BorrowingRecord> ?? new())
                {
                    <tr>
                        <td>@r.Book.Title</td>
                        <td>@r.Borrower.LastName, @r.Borrower.FirstName</td>
                        <td>@r.DueDate.ToString("MMM dd, yyyy")</td>
                        <td>@((DateTime.UtcNow - r.DueDate).Days)</td>
                    </tr>
                }
                @if ((ViewBag.OverdueBooks as List<BorrowingRecord>)?.Count == 0)
                {
                    <tr><td colspan="4" class="text-center text-muted py-3">No overdue books.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
@if ((int)ViewBag.OverdueTotalPages > 1)
{
    <nav class="mb-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @((int)ViewBag.OverduePage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-overduePage="@((int)ViewBag.OverduePage - 1)" asp-route-returnsPage="@ViewBag.ReturnsPage" asp-route-finesByBorrowerPage="@ViewBag.FinesByBorrowerPage" asp-route-repeatOverduePage="@ViewBag.RepeatOverduePage"><i class="bi bi-chevron-left"></i></a>
            </li>
            @for (int i = 1; i <= (int)ViewBag.OverdueTotalPages; i++)
            {
                <li class="page-item @((int)ViewBag.OverduePage == i ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-overduePage="@i" asp-route-returnsPage="@ViewBag.ReturnsPage" asp-route-finesByBorrowerPage="@ViewBag.FinesByBorrowerPage" asp-route-repeatOverduePage="@ViewBag.RepeatOverduePage">@i</a>
                </li>
            }
            <li class="page-item @((int)ViewBag.OverduePage >= (int)ViewBag.OverdueTotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-overduePage="@((int)ViewBag.OverduePage + 1)" asp-route-returnsPage="@ViewBag.ReturnsPage" asp-route-finesByBorrowerPage="@ViewBag.FinesByBorrowerPage" asp-route-repeatOverduePage="@ViewBag.RepeatOverduePage"><i class="bi bi-chevron-right"></i></a>
            </li>
        </ul>
    </nav>
}

<h4>Recent Returns (7 Days)</h4>
<div class="card">
    <div class="card-body p-0 table-responsive">
        <table class="table table-striped mb-0">
            <thead class="table-dark">
                <tr><th>Book</th><th>Borrower</th><th>Returned</th><th>Status</th></tr>
            </thead>
            <tbody>
                @foreach (var r in ViewBag.RecentReturns as List<BorrowingRecord> ?? new())
                {
                    <tr>
                        <td>@r.Book.Title</td>
                        <td>@r.Borrower.LastName, @r.Borrower.FirstName</td>
                        <td>@r.ReturnedAt?.ToString("MMM dd HH:mm")</td>
                        <td>Returned</td>
                    </tr>
                }
                @if ((ViewBag.RecentReturns as List<BorrowingRecord>)?.Count == 0)
                {
                    <tr><td colspan="4" class="text-center text-muted py-3">No returns in the last 7 days.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
@if ((int)ViewBag.ReturnsTotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @((int)ViewBag.ReturnsPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-returnsPage="@((int)ViewBag.ReturnsPage - 1)" asp-route-overduePage="@ViewBag.OverduePage" asp-route-finesByBorrowerPage="@ViewBag.FinesByBorrowerPage" asp-route-repeatOverduePage="@ViewBag.RepeatOverduePage"><i class="bi bi-chevron-left"></i></a>
            </li>
            @for (int i = 1; i <= (int)ViewBag.ReturnsTotalPages; i++)
            {
                <li class="page-item @((int)ViewBag.ReturnsPage == i ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-returnsPage="@i" asp-route-overduePage="@ViewBag.OverduePage" asp-route-finesByBorrowerPage="@ViewBag.FinesByBorrowerPage" asp-route-repeatOverduePage="@ViewBag.RepeatOverduePage">@i</a>
                </li>
            }
            <li class="page-item @((int)ViewBag.ReturnsPage >= (int)ViewBag.ReturnsTotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-returnsPage="@((int)ViewBag.ReturnsPage + 1)" asp-route-overduePage="@ViewBag.OverduePage" asp-route-finesByBorrowerPage="@ViewBag.FinesByBorrowerPage" asp-route-repeatOverduePage="@ViewBag.RepeatOverduePage"><i class="bi bi-chevron-right"></i></a>
            </li>
        </ul>
    </nav>
}

<h4 class="mt-4">Fines by Borrower</h4>
<div class="card mb-4">
    <div class="card-body p-0 table-responsive">
        <table class="table table-striped mb-0">
            <thead class="table-dark">
                <tr><th>Borrower</th><th>Barcode</th><th>Unpaid</th><th>Paid</th><th># Fines</th></tr>
            </thead>
            <tbody>
                @{
                    var finesByBorrowerList = ViewBag.FinesByBorrower as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
                }
                @foreach (var item in finesByBorrowerList)
                {
                    <tr>
                        <td>@item.BorrowerName</td>
                        <td>@item.Barcode</td>
                        <td>PHP @item.TotalUnpaid.ToString("N2")</td>
                        <td>PHP @item.TotalPaid.ToString("N2")</td>
                        <td>@item.FineCount</td>
                    </tr>
                }
                @if (!finesByBorrowerList.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-3">No fine records found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
@if ((int)ViewBag.FinesByBorrowerTotalPages > 1)
{
    <nav class="mb-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @((int)ViewBag.FinesByBorrowerPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-finesByBorrowerPage="@((int)ViewBag.FinesByBorrowerPage - 1)" asp-route-overduePage="@ViewBag.OverduePage" asp-route-returnsPage="@ViewBag.ReturnsPage" asp-route-repeatOverduePage="@ViewBag.RepeatOverduePage"><i class="bi bi-chevron-left"></i></a>
            </li>
            @for (int i = 1; i <= (int)ViewBag.FinesByBorrowerTotalPages; i++)
            {
                <li class="page-item @((int)ViewBag.FinesByBorrowerPage == i ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-finesByBorrowerPage="@i" asp-route-overduePage="@ViewBag.OverduePage" asp-route-returnsPage="@ViewBag.ReturnsPage" asp-route-repeatOverduePage="@ViewBag.RepeatOverduePage">@i</a>
                </li>
            }
            <li class="page-item @((int)ViewBag.FinesByBorrowerPage >= (int)ViewBag.FinesByBorrowerTotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-finesByBorrowerPage="@((int)ViewBag.FinesByBorrowerPage + 1)" asp-route-overduePage="@ViewBag.OverduePage" asp-route-returnsPage="@ViewBag.ReturnsPage" asp-route-repeatOverduePage="@ViewBag.RepeatOverduePage"><i class="bi bi-chevron-right"></i></a>
            </li>
        </ul>
    </nav>
}

<h4 class="mt-4">Repeat Overdue Borrowers</h4>
<div class="card mb-4">
    <div class="card-body p-0 table-responsive">
        <table class="table table-striped mb-0">
            <thead class="table-dark">
                <tr><th>Borrower</th><th>Barcode</th><th>Times Overdue</th><th>Currently Overdue</th></tr>
            </thead>
            <tbody>
                @{
                    var repeatOverdueList = ViewBag.RepeatOverdueBorrowers as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
                }
                @foreach (var item in repeatOverdueList)
                {
                    <tr>
                        <td>@item.BorrowerName</td>
                        <td>@item.Barcode</td>
                        <td>@item.TotalOverdue</td>
                        <td>@(item.CurrentlyOverdue ? "Yes" : "No")</td>
                    </tr>
                }
                @if (!repeatOverdueList.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-3">No overdue records found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
@if ((int)ViewBag.RepeatOverdueTotalPages > 1)
{
    <nav class="mb-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @((int)ViewBag.RepeatOverduePage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-repeatOverduePage="@((int)ViewBag.RepeatOverduePage - 1)" asp-route-overduePage="@ViewBag.OverduePage" asp-route-returnsPage="@ViewBag.ReturnsPage" asp-route-finesByBorrowerPage="@ViewBag.FinesByBorrowerPage"><i class="bi bi-chevron-left"></i></a>
            </li>
            @for (int i = 1; i <= (int)ViewBag.RepeatOverdueTotalPages; i++)
            {
                <li class="page-item @((int)ViewBag.RepeatOverduePage == i ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-repeatOverduePage="@i" asp-route-overduePage="@ViewBag.OverduePage" asp-route-returnsPage="@ViewBag.ReturnsPage" asp-route-finesByBorrowerPage="@ViewBag.FinesByBorrowerPage">@i</a>
                </li>
            }
            <li class="page-item @((int)ViewBag.RepeatOverduePage >= (int)ViewBag.RepeatOverdueTotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-repeatOverduePage="@((int)ViewBag.RepeatOverduePage + 1)" asp-route-overduePage="@ViewBag.OverduePage" asp-route-returnsPage="@ViewBag.ReturnsPage" asp-route-finesByBorrowerPage="@ViewBag.FinesByBorrowerPage"><i class="bi bi-chevron-right"></i></a>
            </li>
        </ul>
    </nav>
}

<!-- Active Borrowings Modal -->
<div class="modal fade" id="activeBorrowingsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-arrow-right-circle me-1"></i>Active Borrowings</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 table-responsive">
                <table class="table table-striped mb-0">
                    <thead class="table-dark">
                        <tr><th>Borrower</th><th>Book</th><th>Borrowed</th><th>Due</th></tr>
                    </thead>
                    <tbody id="activeBorrowingsBody">
                        <tr><td colspan="4" class="text-center text-muted py-3">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Overdue Borrowings Modal -->
<div class="modal fade" id="overdueBorrowingsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-1"></i>Overdue Borrowings</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 table-responsive">
                <table class="table table-striped mb-0">
                    <thead class="table-dark">
                        <tr><th>Borrower</th><th>Book</th><th>Borrowed</th><th>Due</th><th>Days Overdue</th></tr>
                    </thead>
                    <tbody id="overdueBorrowingsBody">
                        <tr><td colspan="5" class="text-center text-muted py-3">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    function showActiveBorrowings() {
        fetch('/Librarian/Reports/GetActiveBorrowings')
            .then(r => r.json())
            .then(data => {
                let tbody = document.getElementById('activeBorrowingsBody');
                if (data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">No active borrowings.</td></tr>';
                } else {
                    tbody.innerHTML = data.map(r => '<tr><td>' + r.borrower + '</td><td>' + r.book + '</td><td>' + r.borrowedAt + '</td><td>' + r.dueDate + '</td></tr>').join('');
                }
                new bootstrap.Modal(document.getElementById('activeBorrowingsModal')).show();
            });
    }

    function showOverdueBorrowings() {
        fetch('/Librarian/Reports/GetOverdueBorrowings')
            .then(r => r.json())
            .then(data => {
                let tbody = document.getElementById('overdueBorrowingsBody');
                if (data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No overdue borrowings.</td></tr>';
                } else {
                    tbody.innerHTML = data.map(r => '<tr><td>' + r.borrower + '</td><td>' + r.book + '</td><td>' + r.borrowedAt + '</td><td>' + r.dueDate + '</td><td>' + r.daysOverdue + '</td></tr>').join('');
                }
                new bootstrap.Modal(document.getElementById('overdueBorrowingsModal')).show();
            });
    }
</script>
