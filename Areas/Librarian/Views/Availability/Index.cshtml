@model List<Book>
@{
    ViewData["Title"] = "Availability";
}
<h2><i class="bi bi-search me-2"></i>Book Availability</h2>
<hr />

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" class="form-control" placeholder="Search by title, author, or ISBN..." value="@ViewBag.Search" />
        <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i> Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
        }
    </div>
</form>

<div class="row">
    @if (Model.Count == 0)
    {
        <div class="col-12"><p class="text-muted text-center py-4">No books found.</p></div>
    }
    @foreach (var book in Model)
    {
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">@book.Title</h5>
                    <h6 class="card-subtitle text-muted">@book.Author</h6>
                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                        <span>Total Copies:</span>
                        <strong>@book.TotalCopies</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Available:</span>
                        <strong class="@(book.AvailableCopies > 0 ? "text-success" : "text-danger")">
                            @book.AvailableCopies
                        </strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Status:</span>
                        @if (book.AvailableCopies > 0)
                        {
                            <span class="badge bg-success">Available</span>
                        }
                        else if (book.AvailableCopies == 0 && book.TotalCopies > 0)
                        {
                            <span class="badge bg-warning text-dark">All Borrowed</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Unavailable</span>
                        }
                    </div>
                    @if (book.ShelfLocation != null)
                    {
                        <div class="d-flex justify-content-between">
                            <span>Shelf:</span>
                            <code>@book.ShelfLocation</code>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
