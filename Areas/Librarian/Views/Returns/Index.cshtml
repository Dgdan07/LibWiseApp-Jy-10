@{
    ViewData["Title"] = "Returns";
}
<h2><i class="bi bi-arrow-left-circle me-2"></i>Returns</h2>
<p class="text-muted">Scan borrower barcode to process book returns.</p>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header fw-bold">Scan Borrower</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Borrower Barcode</label>
                    <input type="text" id="barcodeInput" class="form-control form-control-lg" placeholder="Scan or type barcode..." autofocus autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" />
                </div>
                <div id="borrowerInfo" class="text-muted small">Awaiting scan...</div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header fw-bold">Active Borrowings</div>
            <div class="card-body" id="booksList">
                <p class="text-muted mb-0">Scan a borrower to see their borrowed books.</p>
            </div>
        </div>
    </div>
</div>

<div id="resultAlert" class="mt-3" style="display:none;"></div>

@section Scripts {
    <script src="~/js/librarian-operations.js"></script>
}
