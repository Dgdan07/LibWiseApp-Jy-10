@model List<Fine>
@{
    ViewData["Title"] = "Fines";
}
<h2><i class="bi bi-cash-coin me-2"></i>Fines Management</h2>
<hr />

@if (TempData["Receipt"] != null)
{
    <div id="receiptData" data-message="@TempData["Success"]" data-receipt="@TempData["Receipt"]" style="display:none;"></div>
}

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link @(ViewBag.Status == null ? "active" : "")" asp-action="Index">All</a></li>
    <li class="nav-item"><a class="nav-link @(ViewBag.Status == "Unpaid" ? "active" : "")" asp-action="Index" asp-route-status="Unpaid">Unpaid</a></li>
    <li class="nav-item"><a class="nav-link @(ViewBag.Status == "Paid" ? "active" : "")" asp-action="Index" asp-route-status="Paid">Paid</a></li>
</ul>

<div class="card">
    <div class="card-body p-0 table-responsive">
        <table class="table table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Borrower</th>
                    <th>Book</th>
                    <th>Amount</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No fines found.</td></tr>
                }
                @foreach (var f in Model)
                {
                    <tr>
                        <td>@(f.BorrowingRecord.Borrower?.LastName ?? "-"), @(f.BorrowingRecord.Borrower?.FirstName ?? "-")</td>
                        <td>@f.BorrowingRecord.Book.Title</td>
                        <td class="fw-bold">PHP @f.Amount.ToString("F2")</td>
                        <td>@f.CalculatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (f.Status == "Unpaid")
                            {
                                <span style="color: #ef4444;">Unpaid</span>
                            }
                            else
                            {
                                <span style="color: #10b981;">Paid</span>
                            }
                        </td>
                        <td class="text-end">
                            @if (f.Status == "Unpaid")
                            {
                                <form asp-action="Pay" asp-route-id="@f.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-cash me-1"></i>Collect</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pagination" />

<!-- Receipt Modal -->
<div class="modal fade" id="receiptModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-receipt me-1"></i>Payment Receipt</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="receiptBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" onclick="printReceipt()"><i class="bi bi-printer"></i> Print</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            var data = document.getElementById('receiptData');
            if (data) {
                showToast(data.dataset.message, 'success');
                var r = data.dataset.receipt;
                if (r) {
                    setTimeout(function() {
                        var parts = r.split(' | ');
                        var html = '<div class="text-center mb-3"><i class="bi bi-check-circle-fill text-success fs-1"></i></div><table class="table table-sm table-borderless">';
                        parts.forEach(function(p) {
                            var kv = p.split(': ');
                            html += '<tr><td class="text-muted">' + kv[0] + '</td><td class="text-end fw-semibold">' + (kv[1] || '') + '</td></tr>';
                        });
                        html += '</table>';
                        document.getElementById('receiptBody').innerHTML = html;
                        new bootstrap.Modal(document.getElementById('receiptModal')).show();
                    }, 500);
                }
            }
        });
    </script>
}
