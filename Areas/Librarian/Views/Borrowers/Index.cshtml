@model List<Borrower>
@{
    ViewData["Title"] = "Manage Borrowers";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-badge me-2"></i>Manage Borrowers</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#borrowerModal" onclick="resetBorrowerForm()"><i class="bi bi-plus-circle me-1"></i>Add Borrower</button>
</div>

<div id="alertPlaceholder"></div>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" class="form-control" placeholder="Search by name, barcode, or ID number..." value="@ViewBag.Search" />
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
        @if (!string.IsNullOrEmpty(ViewBag.Search))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
        }
    </div>
</form>

<div id="borrowersContainer" data-ajax-page>
    <div class="card">
        <div class="card-body p-0 table-responsive">
            <table class="table table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Barcode</th>
                        <th>Name</th>
                        <th>Grade</th>
                        <th>ID Number</th>
                        <th>Contact</th>
                        <th>Active</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No borrowers found.</td></tr>
                    }
                    @foreach (var b in Model)
                    {
                        <tr>
                            <td><code>@b.Barcode</code></td>
                            <td>@b.LastName, @b.FirstName</td>
                            <td>@(b.Grade ?? "-")</td>
                            <td>@(b.IDNumber ?? "-")</td>
                            <td>@(b.Email ?? b.Phone ?? "-")</td>
                            <td>
                                @if (b.IsActive)
                                {
                                    <span style="color: green;">Yes</span>
                                }
                                else
                                {
                                    <span style="color: red;">No</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary" onclick="editBorrower(@b.Id)"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" onclick="confirmDeleteBorrower(@b.Id, '@b.FirstName @b.LastName')"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <partial name="_Pagination" />
</div>

<!-- Borrower Create/Edit Modal -->
<div class="modal fade" id="borrowerModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="borrowerForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="borrowerModalTitle">Add Borrower</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="borrowerId" name="Id" />
                    <input type="hidden" id="borrowerCreatedAt" name="CreatedAt" />
                    <div id="borrowerFormErrors" class="text-danger mb-2"></div>
                    <div id="borrowerBarcodeDisplay" class="mb-2" style="display: none;">
                        <label class="form-label fw-semibold">Barcode</label>
                        <div class="form-control bg-light" id="borrowerBarcodeText"></div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="borrowerFirstName" class="form-label">First Name</label>
                            <input id="borrowerFirstName" name="FirstName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label for="borrowerLastName" class="form-label">Last Name</label>
                            <input id="borrowerLastName" name="LastName" class="form-control" required />
                        </div>
                        <div class="col-md-4">
                            <label for="borrowerEmail" class="form-label">Email</label>
                            <input id="borrowerEmail" name="Email" class="form-control" type="email" />
                        </div>
                        <div class="col-md-4">
                            <label for="borrowerPhone" class="form-label">Phone</label>
                            <input id="borrowerPhone" name="Phone" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label for="borrowerGrade" class="form-label">Grade / Year</label>
                            <input id="borrowerGrade" name="Grade" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label for="borrowerIDNumber" class="form-label">ID Number</label>
                            <input id="borrowerIDNumber" name="IDNumber" class="form-control" />
                        </div>
                        <div class="col-md-8">
                            <label for="borrowerAddress" class="form-label">Address</label>
                            <input id="borrowerAddress" name="Address" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <div class="form-check mt-4">
                                <input id="borrowerIsActive" name="IsActive" class="form-check-input" type="checkbox" value="true" checked />
                                <label for="borrowerIsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteBorrowerModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="deleteBorrowerName"></strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBorrowerBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/librarian-borrowers.js"></script>
