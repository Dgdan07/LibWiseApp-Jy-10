@model Borrower
@{
    ViewData["Title"] = "Edit Borrower";
}
<h2><i class="bi bi-pencil me-2"></i>Edit Borrower</h2>
<hr />
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedAt" />
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Barcode" class="form-label"></label>
            <input asp-for="Barcode" class="form-control" required />
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="FirstName" class="form-label">First Name</label>
            <input asp-for="FirstName" class="form-control" required />
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="LastName" class="form-label">Last Name</label>
            <input asp-for="LastName" class="form-control" required />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" type="email" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Phone" class="form-label"></label>
            <input asp-for="Phone" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Grade" class="form-label">Grade / Year</label>
            <input asp-for="Grade" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="IDNumber" class="form-label">ID Number</label>
            <input asp-for="IDNumber" class="form-control" />
        </div>
        <div class="col-md-8 mb-3">
            <label asp-for="Address" class="form-label"></label>
            <input asp-for="Address" class="form-control" />
        </div>
    </div>
    <div class="mb-3 form-check">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Active</label>
    </div>
    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Update</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
