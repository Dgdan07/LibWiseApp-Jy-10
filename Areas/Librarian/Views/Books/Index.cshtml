@model List<Book>
@{
    ViewData["Title"] = "Manage Books";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-book me-2"></i>Manage Books</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Book</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" class="form-control" placeholder="Search by title, author, or ISBN..." value="@ViewBag.Search" />
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
        @if (!string.IsNullOrEmpty(ViewBag.Search))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
        }
    </div>
</form>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Category</th>
                    <th class="text-center">Total</th>
                    <th class="text-center">Available</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No books found.</td></tr>
                }
                @foreach (var book in Model)
                {
                    <tr>
                        <td>@book.Title</td>
                        <td>@book.Author</td>
                        <td>@(book.Category?.Name ?? "-")</td>
                        <td class="text-center">@book.TotalCopies</td>
                        <td class="text-center">@book.AvailableCopies</td>
                        <td>
                            @if (book.AvailableCopies > 0)
                            {
                                <span class="badge bg-success">Available</span>
                            }
                            else if (book.AvailableCopies == 0 && book.TotalCopies > 0)
                            {
                                <span class="badge bg-warning text-dark">All Borrowed</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Unavailable</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <form asp-action="Delete" asp-route-id="@book.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this book?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pagination" />
