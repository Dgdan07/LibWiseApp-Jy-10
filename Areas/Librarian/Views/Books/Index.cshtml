@model List<Book>
@{
    ViewData["Title"] = "Manage Books";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-book me-2"></i>Manage Books</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#bookModal" onclick="resetBookForm()"><i class="bi bi-plus-circle me-1"></i>Add Book</button>
</div>

<div id="alertPlaceholder"></div>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" class="form-control" placeholder="Search by title, author, or ISBN..." value="@ViewBag.Search" />
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
        @if (!string.IsNullOrEmpty(ViewBag.Search))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
        }
    </div>
</form>

<div id="booksContainer" data-ajax-page>
    <div class="card">
        <div class="card-body p-0 table-responsive">
            <table class="table table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th class="text-center">Total</th>
                        <th class="text-center">Available</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No books found.</td></tr>
                    }
                    @foreach (var book in Model)
                    {
                        <tr>
                            <td>@book.Title</td>
                            <td>@book.Author</td>
                            <td>@(book.Category?.Name ?? "-")</td>
                            <td class="text-center">@book.TotalCopies</td>
                            <td class="text-center">@book.AvailableCopies</td>
                            <td>
                                @if (book.AvailableCopies > 0)
                                {
                                    <span style="color: green;">Available</span>
                                }
                                else if (book.AvailableCopies == 0 && book.TotalCopies > 0)
                                {
                                    <span style="color: darkorange;">All Borrowed</span>
                                }
                                else
                                {
                                    <span style="color: red;">Unavailable</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary" onclick="editBook(@book.Id)"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" onclick="confirmDeleteBook(@book.Id, '@book.Title')"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <partial name="_Pagination" />
</div>

<!-- Book Create/Edit Modal -->
<div class="modal fade" id="bookModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="bookForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="bookModalTitle">Add Book</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="bookId" name="Id" />
                    <input type="hidden" id="bookCreatedAt" name="CreatedAt" />
                    <div id="bookFormErrors" class="text-danger mb-2"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="bookISBN" class="form-label">ISBN</label>
                            <input id="bookISBN" name="ISBN" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="bookTitle" class="form-label">Title</label>
                            <input id="bookTitle" name="Title" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label for="bookAuthor" class="form-label">Author</label>
                            <input id="bookAuthor" name="Author" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label for="bookPublisher" class="form-label">Publisher</label>
                            <input id="bookPublisher" name="Publisher" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label for="bookCategoryId" class="form-label">Category</label>
                            <select id="bookCategoryId" name="CategoryId" class="form-select">
                                <option value="">-- Select --</option>
                                @foreach (var cat in ViewBag.Categories as List<Category> ?? new())
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label for="bookPublicationYear" class="form-label">Year</label>
                            <input id="bookPublicationYear" name="PublicationYear" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label for="bookTotalCopies" class="form-label">Total Copies</label>
                            <input id="bookTotalCopies" name="TotalCopies" class="form-control" min="1" />
                        </div>
                        <div class="col-md-3">
                            <label for="bookAvailableCopies" class="form-label">Available Copies</label>
                            <input id="bookAvailableCopies" name="AvailableCopies" class="form-control" min="0" />
                        </div>
                        <div class="col-md-3">
                            <label for="bookShelfLocation" class="form-label">Shelf Location</label>
                            <input id="bookShelfLocation" name="ShelfLocation" class="form-control" />
                        </div>
                        <div class="col-md-12">
                            <label for="bookDescription" class="form-label">Description</label>
                            <textarea id="bookDescription" name="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-3">
                            <div class="form-check mt-4">
                                <input id="bookIsActive" name="IsActive" class="form-check-input" type="checkbox" value="true" checked />
                                <label for="bookIsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteBookModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="deleteBookTitle"></strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBookBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/librarian-books.js"></script>
