@{
    ViewData["Title"] = "Reports";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-file-earmark-bar-graph me-2"></i>System Reports</h2>
    <a asp-action="ExportCsv" class="btn btn-success"><i class="bi bi-download me-1"></i>Export CSV</a>
</div>
<hr />

<div id="alertPlaceholder"></div>

<div class="row">
    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm dashboard-card" style="border-left: 4px solid #4361ee;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-book fs-2" style="color: #4361ee;"></i>
                        <span class="text-muted small">Total Books</span>
                    </div>
                    <p class="fs-3 fw-semibold mb-0 text-end">@ViewBag.TotalBooks</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm dashboard-card" style="border-left: 4px solid #6366f1;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-people fs-2" style="color: #6366f1;"></i>
                        <span class="text-muted small">Total Borrowers</span>
                    </div>
                    <p class="fs-3 fw-semibold mb-0 text-end">@ViewBag.TotalBorrowers</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm dashboard-card" style="border-left: 4px solid #f59e0b; cursor: pointer;" onclick="showActiveBorrowings()">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-arrow-right-circle fs-2" style="color: #f59e0b;"></i>
                        <span class="text-muted small">Active Borrowings</span>
                    </div>
                    <p class="fs-3 fw-semibold mb-0 text-end">@ViewBag.ActiveBorrowings</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm dashboard-card" style="border-left: 4px solid #ef4444; cursor: pointer;" onclick="showOverdueBorrowings()">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-triangle fs-2" style="color: #ef4444;"></i>
                        <span class="text-muted small">Overdue</span>
                    </div>
                    <p class="fs-3 fw-semibold mb-0 text-end">@ViewBag.OverdueCount</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm dashboard-card" style="border-left: 4px solid #0891b2; cursor: pointer;" onclick="showUnpaidFines()">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-cash-coin fs-2" style="color: #0891b2;"></i>
                        <span class="text-muted small">Unpaid Fines</span>
                    </div>
                    <p class="fs-3 fw-semibold mb-0 text-end">@ViewBag.UnpaidFinesCount</p>
                </div>
            </div>
        </div>
    </div>
</div>

<h4 class="mt-4">Borrowing Records</h4>
<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="date" name="from" class="form-control form-control-sm" value="@ViewBag.FromDate?.ToString("yyyy-MM-dd")" placeholder="From" />
    </div>
    <div class="col-auto">
        <input type="date" name="to" class="form-control form-control-sm" value="@ViewBag.ToDate?.ToString("yyyy-MM-dd")" placeholder="To" />
    </div>
    <div class="col-auto">
        <select name="status" class="form-select form-select-sm">
            <option value="">All Status</option>
            <option value="Active" selected="@(ViewBag.Status == "Active")">Active</option>
            <option value="Returned" selected="@(ViewBag.Status == "Returned")">Returned</option>
            <option value="Overdue" selected="@(ViewBag.Status == "Overdue")">Overdue</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary">Filter</button>
    </div>
    @if (ViewBag.FromDate != null || ViewBag.ToDate != null || !string.IsNullOrEmpty(ViewBag.Status))
    {
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-sm btn-outline-danger">Clear</a>
        </div>
    }
</form>

<div class="card">
    <div class="card-body p-0 table-responsive">
        <table class="table table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Book</th>
                    <th>Borrower</th>
                    <th>Borrowed</th>
                    <th>Due</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in ViewBag.RecentBorrowings as List<BorrowingRecord> ?? new())
                {
                    <tr>
                        <td>@r.Book.Title</td>
                        <td>@r.Borrower.LastName, @r.Borrower.FirstName</td>
                        <td>@r.BorrowedAt.ToString("MMM dd")</td>
                        <td>@r.DueDate.ToString("MMM dd")</td>
                        <td>
                            @if (r.Status == "Active" && r.DueDate < DateTime.UtcNow)
                            {
                                <span style="color: red;">Overdue</span>
                            }
                            else if (r.Status == "Active")
                            {
                                <span style="color: #4361ee;">Active</span>
                            }
                            else
                            {
                                <span style="color: gray;">Returned</span>
                            }
                        </td>
                    </tr>
                }
                @if ((ViewBag.RecentBorrowings as List<BorrowingRecord>)?.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted py-3">No borrowing records found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pagination" />

<h4 class="mt-4">Fines by Borrower</h4>
<div class="card mb-4">
    <div class="card-body p-0 table-responsive">
        <table class="table table-striped mb-0">
            <thead class="table-dark">
                <tr><th>Borrower</th><th>Barcode</th><th>Unpaid</th><th>Paid</th><th># Fines</th></tr>
            </thead>
            <tbody>
                @{
                    var adminFinesByBorrowerList = ViewBag.FinesByBorrower as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
                }
                @foreach (var item in adminFinesByBorrowerList)
                {
                    <tr>
                        <td>@item.BorrowerName</td>
                        <td>@item.Barcode</td>
                        <td>PHP @item.TotalUnpaid.ToString("N2")</td>
                        <td>PHP @item.TotalPaid.ToString("N2")</td>
                        <td>@item.FineCount</td>
                    </tr>
                }
                @if (!adminFinesByBorrowerList.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-3">No fine records found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
@{
    int adminFinesByBorrowerTotalPages = Math.Max((int)ViewBag.FinesByBorrowerTotalPages, 1);
}
<nav class="mb-4">
    <ul class="pagination justify-content-end">
        <li class="page-item @((int)ViewBag.FinesByBorrowerPage <= 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-finesByBorrowerPage="@((int)ViewBag.FinesByBorrowerPage - 1)" asp-route-page="@ViewBag.Page" asp-route-from="@ViewBag.FromDate" asp-route-to="@ViewBag.ToDate" asp-route-status="@ViewBag.Status" asp-route-repeatOverduePage="@ViewBag.RepeatOverduePage"><i class="bi bi-chevron-left"></i></a>
        </li>
        <li class="page-item disabled">
            <span class="page-link">Page @ViewBag.FinesByBorrowerPage of @adminFinesByBorrowerTotalPages</span>
        </li>
        <li class="page-item @((int)ViewBag.FinesByBorrowerPage >= adminFinesByBorrowerTotalPages ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-finesByBorrowerPage="@((int)ViewBag.FinesByBorrowerPage + 1)" asp-route-page="@ViewBag.Page" asp-route-from="@ViewBag.FromDate" asp-route-to="@ViewBag.ToDate" asp-route-status="@ViewBag.Status" asp-route-repeatOverduePage="@ViewBag.RepeatOverduePage"><i class="bi bi-chevron-right"></i></a>
        </li>
    </ul>
</nav>

<h4 class="mt-4">Repeat Overdue Borrowers</h4>
<div class="card mb-4">
    <div class="card-body p-0 table-responsive">
        <table class="table table-striped mb-0">
            <thead class="table-dark">
                <tr><th>Borrower</th><th>Barcode</th><th>Times Overdue</th><th>Currently Overdue</th></tr>
            </thead>
            <tbody>
                @{
                    var adminRepeatOverdueList = ViewBag.RepeatOverdueBorrowers as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
                }
                @foreach (var item in adminRepeatOverdueList)
                {
                    <tr>
                        <td>@item.BorrowerName</td>
                        <td>@item.Barcode</td>
                        <td>@item.TotalOverdue</td>
                        <td>@(item.CurrentlyOverdue ? "Yes" : "No")</td>
                    </tr>
                }
                @if (!adminRepeatOverdueList.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-3">No overdue records found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
@{
    int adminRepeatOverdueTotalPages = Math.Max((int)ViewBag.RepeatOverdueTotalPages, 1);
}
<nav class="mb-4">
    <ul class="pagination justify-content-end">
        <li class="page-item @((int)ViewBag.RepeatOverduePage <= 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-repeatOverduePage="@((int)ViewBag.RepeatOverduePage - 1)" asp-route-page="@ViewBag.Page" asp-route-from="@ViewBag.FromDate" asp-route-to="@ViewBag.ToDate" asp-route-status="@ViewBag.Status" asp-route-finesByBorrowerPage="@ViewBag.FinesByBorrowerPage"><i class="bi bi-chevron-left"></i></a>
        </li>
        <li class="page-item disabled">
            <span class="page-link">Page @ViewBag.RepeatOverduePage of @adminRepeatOverdueTotalPages</span>
        </li>
        <li class="page-item @((int)ViewBag.RepeatOverduePage >= adminRepeatOverdueTotalPages ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-repeatOverduePage="@((int)ViewBag.RepeatOverduePage + 1)" asp-route-page="@ViewBag.Page" asp-route-from="@ViewBag.FromDate" asp-route-to="@ViewBag.ToDate" asp-route-status="@ViewBag.Status" asp-route-finesByBorrowerPage="@ViewBag.FinesByBorrowerPage"><i class="bi bi-chevron-right"></i></a>
        </li>
    </ul>
</nav>

<!-- Unpaid Fines Modal -->
<div class="modal fade" id="unpaidFinesModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-cash-coin me-1"></i>Unpaid Fines</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 table-responsive">
                <table class="table table-striped mb-0">
                    <thead class="table-dark">
                        <tr><th>Borrower</th><th>Book</th><th>Amount</th><th>Due Date</th><th>Calculated</th></tr>
                    </thead>
                    <tbody id="unpaidFinesBody">
                        <tr><td colspan="5" class="text-center text-muted py-3">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Active Borrowings Modal -->
<div class="modal fade" id="activeBorrowingsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-arrow-right-circle me-1"></i>Active Borrowings</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 table-responsive">
                <table class="table table-striped mb-0">
                    <thead class="table-dark">
                        <tr><th>Borrower</th><th>Book</th><th>Borrowed</th><th>Due</th></tr>
                    </thead>
                    <tbody id="activeBorrowingsBody">
                        <tr><td colspan="4" class="text-center text-muted py-3">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Overdue Borrowings Modal -->
<div class="modal fade" id="overdueBorrowingsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-1"></i>Overdue Borrowings</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 table-responsive">
                <table class="table table-striped mb-0">
                    <thead class="table-dark">
                        <tr><th>Borrower</th><th>Book</th><th>Borrowed</th><th>Due</th><th>Days Overdue</th></tr>
                    </thead>
                    <tbody id="overdueBorrowingsBody">
                        <tr><td colspan="5" class="text-center text-muted py-3">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/admin-reports.js"></script>
