@model List<AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
}
<h2><i class="bi bi-journal-text me-2"></i>Audit Logs</h2>
<hr />
<form method="get" class="row g-2 mb-3">
    <div class="col-auto flex-grow-1">
        <input type="text" name="search" class="form-control" placeholder="Search logs..." value="@ViewBag.Search" />
    </div>
    <div class="col-auto">
        <select name="actionType" class="form-select">
            <option value="">All Actions</option>
            @foreach (var a in ViewBag.ActionTypes as List<string> ?? new())
            {
                <option value="@a" selected="@(ViewBag.ActionType == a)">@a</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
    </div>
    @if (!string.IsNullOrEmpty(ViewBag.Search) || !string.IsNullOrEmpty(ViewBag.ActionType))
    {
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
        </div>
    }
</form>
<div id="auditLogsContainer" data-ajax-page>
    <div class="card">
        <div class="card-body p-0 table-responsive">
            <table class="table table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Time</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">No logs found.</td></tr>
                    }
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="text-nowrap">@log.Timestamp.ToString("MMM dd HH:mm")</td>
                            <td>@(log.User?.UserName ?? "-")</td>
                            <td class="fw-semibold">@log.Action</td>
                            <td>@log.EntityType @(log.EntityId != null ? $"#{log.EntityId}" : "")</td>
                            <td class="text-muted small">@log.Details</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <partial name="_Pagination" />
</div>
