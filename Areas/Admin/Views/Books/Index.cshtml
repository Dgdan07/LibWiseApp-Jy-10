@model List<Book>
@{
    ViewData["Title"] = "Book Catalog";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-book me-2"></i>Book Catalog</h2>
    <span class="text-muted small"><i class="bi bi-eye me-1"></i>Read-only — managed by Librarian</span>
</div>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" class="form-control" placeholder="Search by title, author, or ISBN..." value="@ViewBag.Search" />
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
        @if (!string.IsNullOrEmpty(ViewBag.Search))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
        }
    </div>
</form>

<div id="booksContainer" data-ajax-page>
    <div class="card">
        <div class="card-body p-0 table-responsive">
            <table class="table table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th class="text-center">Total</th>
                        <th class="text-center">Available</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">No books found.</td></tr>
                    }
                    @foreach (var book in Model)
                    {
                        <tr>
                            <td>@book.Title</td>
                            <td>@book.Author</td>
                            <td>@(book.Category?.Name ?? "-")</td>
                            <td class="text-center">@book.TotalCopies</td>
                            <td class="text-center">@book.AvailableCopies</td>
                            <td>
                                @if (book.AvailableCopies > 0)
                                {
                                    <span style="color: green;">Available</span>
                                }
                                else if (book.AvailableCopies == 0 && book.TotalCopies > 0)
                                {
                                    <span style="color: darkorange;">All Borrowed</span>
                                }
                                else
                                {
                                    <span style="color: red;">Unavailable</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <partial name="_Pagination" />
</div>
