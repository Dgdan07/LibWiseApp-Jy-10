<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibWise</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="d-flex" style="height: 100vh;">
            <nav class="bg-dark text-white sidebar d-flex flex-column">
                <div class="p-3 border-bottom border-secondary text-center">
                    <a class="text-white text-decoration-none fw-bold fs-5" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-book fs-4"></i><span class="nav-text ms-2">LibWise</span>
                    </a>
                </div>
                <div class="p-3 small text-secondary text-center">
                    <i class="bi bi-person-circle fs-5 d-block d-md-none"></i>
                    <span class="nav-text">Logged in as <strong class="text-white d-block">@User.Identity.Name</strong></span>
                    <span class="text-info-emphasis fw-semibold mt-1">@(User.IsInRole("Admin") ? "Admin" : User.IsInRole("Librarian") ? "Librarian" : "Assistant")</span>
                </div>
                <ul class="nav flex-column px-2 flex-grow-1" style="overflow-y: auto; min-height: 0;">
                    @{
                        var area = ViewContext.RouteData.Values["area"]?.ToString();
                        var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item"><a class="nav-link text-white@(area=="Admin"&&ctrl=="Dashboard"?" active":"")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i><span class="nav-text ms-2">Dashboard</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Admin"&&ctrl=="Users"?" active":"")" asp-area="Admin" asp-controller="Users" asp-action="Index"><i class="bi bi-people"></i><span class="nav-text ms-2">Users</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Admin"&&ctrl=="Books"?" active":"")" asp-area="Admin" asp-controller="Books" asp-action="Index"><i class="bi bi-book"></i><span class="nav-text ms-2">Book Catalog</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Admin"&&ctrl=="Categories"?" active":"")" asp-area="Admin" asp-controller="Categories" asp-action="Index"><i class="bi bi-tags"></i><span class="nav-text ms-2">Categories</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Admin"&&ctrl=="Reports"?" active":"")" asp-area="Admin" asp-controller="Reports" asp-action="Index"><i class="bi bi-file-earmark-bar-graph"></i><span class="nav-text ms-2">Reports</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Admin"&&ctrl=="AuditLogs"?" active":"")" asp-area="Admin" asp-controller="AuditLogs" asp-action="Index"><i class="bi bi-journal-text"></i><span class="nav-text ms-2">Audit Logs</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Admin"&&ctrl=="Config"?" active":"")" asp-area="Admin" asp-controller="Config" asp-action="Index"><i class="bi bi-gear"></i><span class="nav-text ms-2">Configuration</span></a></li>
                    }
                    @if (User.IsInRole("Librarian"))
                    {
                        <li class="nav-item"><a class="nav-link text-white@(area=="Librarian"&&ctrl=="Dashboard"?" active":"")" asp-area="Librarian" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i><span class="nav-text ms-2">Dashboard</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Librarian"&&ctrl=="Books"?" active":"")" asp-area="Librarian" asp-controller="Books" asp-action="Index"><i class="bi bi-book"></i><span class="nav-text ms-2">Books</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Librarian"&&ctrl=="Borrowers"?" active":"")" asp-area="Librarian" asp-controller="Borrowers" asp-action="Index"><i class="bi bi-person-badge"></i><span class="nav-text ms-2">Borrowers</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Librarian"&&ctrl=="Borrowing"?" active":"")" asp-area="Librarian" asp-controller="Borrowing" asp-action="Index"><i class="bi bi-arrow-right-circle"></i><span class="nav-text ms-2">Borrowing</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Librarian"&&ctrl=="Returns"?" active":"")" asp-area="Librarian" asp-controller="Returns" asp-action="Index"><i class="bi bi-arrow-left-circle"></i><span class="nav-text ms-2">Returns</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Librarian"&&ctrl=="Fines"?" active":"")" asp-area="Librarian" asp-controller="Fines" asp-action="Index"><i class="bi bi-cash-coin"></i><span class="nav-text ms-2">Fines</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Librarian"&&ctrl=="Availability"?" active":"")" asp-area="Librarian" asp-controller="Availability" asp-action="Index"><i class="bi bi-search"></i><span class="nav-text ms-2">Availability</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="Librarian"&&ctrl=="Reports"?" active":"")" asp-area="Librarian" asp-controller="Reports" asp-action="Index"><i class="bi bi-file-earmark-bar-graph"></i><span class="nav-text ms-2">Reports</span></a></li>
                    }
                    @if (User.IsInRole("AssistantLibrarian"))
                    {
                        <li class="nav-item"><a class="nav-link text-white@(area=="AssistantLibrarian"&&ctrl=="Dashboard"?" active":"")" asp-area="AssistantLibrarian" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i><span class="nav-text ms-2">Dashboard</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="AssistantLibrarian"&&ctrl=="Borrowing"?" active":"")" asp-area="AssistantLibrarian" asp-controller="Borrowing" asp-action="Index"><i class="bi bi-arrow-right-circle"></i><span class="nav-text ms-2">Borrowing</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="AssistantLibrarian"&&ctrl=="Returns"?" active":"")" asp-area="AssistantLibrarian" asp-controller="Returns" asp-action="Index"><i class="bi bi-arrow-left-circle"></i><span class="nav-text ms-2">Returns</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="AssistantLibrarian"&&ctrl=="Fines"?" active":"")" asp-area="AssistantLibrarian" asp-controller="Fines" asp-action="Index"><i class="bi bi-cash-coin"></i><span class="nav-text ms-2">Fine Collection</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="AssistantLibrarian"&&ctrl=="Availability"?" active":"")" asp-area="AssistantLibrarian" asp-controller="Availability" asp-action="Index"><i class="bi bi-search"></i><span class="nav-text ms-2">Availability</span></a></li>
                        <li class="nav-item"><a class="nav-link text-white@(area=="AssistantLibrarian"&&ctrl=="BorrowerInfo"?" active":"")" asp-area="AssistantLibrarian" asp-controller="BorrowerInfo" asp-action="Index"><i class="bi bi-person"></i><span class="nav-text ms-2">Borrower Info</span></a></li>
                    }
                </ul>
                <div class="px-2 pt-3 pb-2 border-top border-secondary">
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light w-100 d-flex align-items-center justify-content-center py-2">
                            <i class="bi bi-box-arrow-left"></i><span class="nav-text ms-2">Logout</span>
                        </button>
                    </form>
                </div>
            </nav>
            <main class="flex-grow-1 p-4 bg-light" style="overflow-y: auto;">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <div class="container mt-5">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    <div aria-live="polite" aria-atomic="true" class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
        <div id="toastContainer" class="toast-container"></div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
