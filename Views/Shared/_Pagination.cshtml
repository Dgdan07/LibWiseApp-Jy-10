@{
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var from = ViewBag.FromDate?.ToString("yyyy-MM-dd");
    var to = ViewBag.ToDate?.ToString("yyyy-MM-dd");
    var status = ViewBag.Status;
    var finesByBorrowerPage = ViewBag.FinesByBorrowerPage;
    var repeatOverduePage = ViewBag.RepeatOverduePage;
}
@if (ViewBag.TotalPages > 1)
{
    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(ViewBag.Page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="@action"
                   asp-route-search="@ViewBag.Search"
                   asp-route-status="@status"
                   asp-route-from="@from"
                   asp-route-to="@to"
                   asp-route-page="@(ViewBag.Page - 1)"
                   asp-route-finesByBorrowerPage="@finesByBorrowerPage"
                   asp-route-repeatOverduePage="@repeatOverduePage"><i class="bi bi-chevron-left"></i></a>
            </li>
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" asp-action="@action"
                       asp-route-search="@ViewBag.Search"
                       asp-route-status="@status"
                       asp-route-from="@from"
                       asp-route-to="@to"
                       asp-route-page="@i"
                       asp-route-finesByBorrowerPage="@finesByBorrowerPage"
                       asp-route-repeatOverduePage="@repeatOverduePage">@i</a>
                </li>
            }
            <li class="page-item @(ViewBag.Page >= ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="@action"
                   asp-route-search="@ViewBag.Search"
                   asp-route-status="@status"
                   asp-route-from="@from"
                   asp-route-to="@to"
                   asp-route-page="@(ViewBag.Page + 1)"
                   asp-route-finesByBorrowerPage="@finesByBorrowerPage"
                   asp-route-repeatOverduePage="@repeatOverduePage"><i class="bi bi-chevron-right"></i></a>
            </li>
        </ul>
    </nav>
}
