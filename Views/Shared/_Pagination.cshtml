@{
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}
@if (ViewBag.TotalPages > 1)
{
    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(ViewBag.Page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="@action" asp-route-search="@ViewBag.Search" asp-route-page="@(ViewBag.Page - 1)">Previous</a>
            </li>
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" asp-action="@action" asp-route-search="@ViewBag.Search" asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(ViewBag.Page >= ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="@action" asp-route-search="@ViewBag.Search" asp-route-page="@(ViewBag.Page + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
