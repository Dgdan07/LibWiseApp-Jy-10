@{
    ViewData["Title"] = "Error";
}
<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 5rem;"></i>
    <h1 class="display-4 mt-3">Something went wrong</h1>
    <p class="lead text-muted">An unexpected error occurred while processing your request.</p>
    <p class="text-muted">Please try again or contact support if the problem persists.</p>
    <a href="/" class="btn btn-primary mt-3"><i class="bi bi-house-door me-1"></i>Back to Home</a>
</div>
